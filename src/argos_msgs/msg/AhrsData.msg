std_msgs/Header header
float32 roll           # degrees, -180 to +180 (relative to level reference)
float32 pitch          # degrees, -90 to +90 (relative to level reference)
float32 yaw            # degrees, 0 to 360 (clockwise from magnetic north)
float32 heading        # degrees, tilt-compensated compass heading 0-360
float32 q_w            # orientation quaternion
float32 q_x
float32 q_y
float32 q_z
